# App Configuration
APP_NAME=Food Expiry Tracker
DEBUG=True
TIMEZONE=Asia/Kolkata

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./food_tracker.db

# API Keys
EDAMAM_APP_ID=your_edamam_app_id
EDAMAM_APP_KEY=your_edamam_app_key
GEMINI_API_KEY=your_gemini_api_key_here
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
LOGMEAL_API_KEY=your_logmeal_api_key

# API Base URLs
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org/api/v0
EDAMAM_RECIPE_URL=https://api.edamam.com/search
MAILGUN_BASE_URL=https://api.mailgun.net/v3

# CORS
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000
